PORT=3001
PUBLIC_SITE_URL=https://yourdomain.com
FRONTEND_ORIGIN=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
CROSS_SITE_COOKIES=true

ADMIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret

# Recommended for production persistence
DATABASE_URL=

# Optional Firebase Firestore mirror for forms/client portal audit data
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or paste the full Firebase service account JSON instead of the three fields above
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional email notifications
RESEND_API_KEY=
EMAIL_FROM=
CONTACT_EMAIL=info@yourdomain.com

# Optional WhatsApp notifications
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ADMIN_RECIPIENT_NUMBER=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Optional analytics and SEO integrations
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GTM_CONTAINER_ID=
GSC_SITE_URL=
GSC_ACCESS_TOKEN=
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
PAGESPEED_API_KEY=

# Optional client portal contact fallback
CLIENT_PORTAL_SESSION_SECRET=
CLIENT_PORTAL_SESSION_DAYS=365
CLIENT_PORTAL_FALLBACK_EMAIL=
CLIENT_PORTAL_WHATSAPP_LINK=

# Optional public full-preview email gate
PREVIEW_ACCESS_SECRET=
PREVIEW_ACCESS_DAYS=365
