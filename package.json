{
  "name": "@workspace/backend",
  "version": "0.0.0",
  "license": "MIT",
  "main": "app.js",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": "22.x"
  },
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server run dev",
    "build": "pnpm run typecheck && pnpm run build:backend",
    "build:backend": "pnpm --filter @workspace/api-server run build",
    "build:full": "pnpm --dir ../frontend run build && pnpm --filter @workspace/api-server run build:with-frontend",
    "start": "node app.js",
    "start:api": "pnpm --filter @workspace/api-server run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push-force": "pnpm --filter @workspace/db run push-force",
    "codegen": "pnpm --filter @workspace/api-spec run codegen"
  },
  "dependencies": {
    "express": "^5"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
